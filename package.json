{
  "name": "@playcanvas/font-tools",
  "version": "0.1.0",
  "description": "Generate PlayCanvas MSDF font assets (JSON + atlas PNG) from TTF/OTF fonts, in Node or the browser.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "msdf",
    "sdf",
    "font",
    "font-generation",
    "bmfont",
    "atlas",
    "text",
    "playcanvas"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playcanvas/font-tools.git"
  },
  "homepage": "https://github.com/playcanvas/font-tools#readme",
  "bugs": {
    "url": "https://github.com/playcanvas/font-tools/issues"
  },
  "exports": {
    ".": "./src/index.js",
    "./kerning-fontkit": "./src/kerning-fontkit.js",
    "./image-backend-node": "./src/image-backend-node.js",
    "./glyph-source-msdfgen": "./src/glyph-source-msdfgen.js"
  },
  "bin": {
    "pcfont": "./bin/pcfont.js"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "test": "node test/packing.test.mjs && node test/generate.test.mjs && node test/image-backend.test.mjs"
  },
  "dependencies": {
    "@playcanvas/msdfgen-wasm": "^0.1.0",
    "fontkit": "^2.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
